# Copy to .env and fill in.  BookRAG auto-selects the provider:
#   - if GROQ_API_KEY is set   -> Groq (free, no GPU needed)  [recommended]
#   - else                     -> local Ollama
#   - if BOOKRAG_MOCK_LLM=1     -> fake model (no key, for UI testing only)

# ── Groq (free cloud LLM — get a key at https://console.groq.com/keys) ──
GROQ_API_KEY=

# Model tags (Groq). Override only if you want different ones.
BOOKRAG_MODEL_ROUTER=llama-3.1-8b-instant
BOOKRAG_MODEL_GENERAL=llama-3.1-8b-instant
BOOKRAG_MODEL_HEAVY=llama-3.1-8b-instant
BOOKRAG_LLM_TIMEOUT=120

# ── UI testing without any key: set to 1 ──
BOOKRAG_MOCK_LLM=0

# ── Embeddings (local CPU, no GPU) ──
BOOKRAG_EMBED_MODEL=BAAI/bge-small-en-v1.5

# ── Multimodal upload (auto-detected; needs optional deps — see requirements.txt) ──
BOOKRAG_OCR=auto         # image / scanned-PDF OCR: auto | on | off
BOOKRAG_AUDIO=auto       # audio transcription: auto | off
BOOKRAG_WHISPER_MODEL=base

# ── OCR fallback for scanned PDFs: auto | on | off ──
BOOKRAG_OCR=auto

# ── SEC etiquette for acquire.py ──
CONTACT_EMAIL=royalekiller786@gmail.com

# ── (Optional) local Ollama instead of Groq ──
# OLLAMA_BASE_URL=http://localhost:11434
